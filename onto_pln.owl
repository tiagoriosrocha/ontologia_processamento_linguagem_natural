  <rdfs:subClassOf rdf:resource="#RedeNeuralRecorrente" />
  <rdfs:label xml:lang="pt">GRU</rdfs:label>
  <rdfs:label xml:lang="en">GRU</rdfs:label>
  <rdfs:comment>Gated Recurrent Unit: variação simplificada de LSTM</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#RedeNeuralConvolucional">
  <rdfs:subClassOf rdf:resource="#ArquiteturaNeural" />
