</owl:Class>

<owl:Class rdf:about="#AvaliacaoIntris">
  <rdfs:subClassOf rdf:resource="#Avaliacao" />
  <rdfs:label xml:lang="pt">Avaliação Intrínseca</rdfs:label>
  <rdfs:label xml:lang="en">Intrinsic Evaluation</rdfs:label>
  <rdfs:comment>Avaliação baseada em métricas automáticas</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#AvaliacaoExtrin">
  <rdfs:subClassOf rdf:resource="#Avaliacao" />
  <rdfs:label xml:lang="pt">Avaliação Extrínseca</rdfs:label>
  <rdfs:label xml:lang="en">Extrinsic Evaluation</rdfs:label>
  <rdfs:comment>Avaliação baseada no desempenho em tarefas reais</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#TesteSignificannciEstatistica">
  <rdfs:subClassOf rdf:resource="#Avaliacao" />
