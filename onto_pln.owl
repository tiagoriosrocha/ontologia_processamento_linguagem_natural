  <skos:altLabel>CNN</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#Transformer">
  <rdfs:subClassOf rdf:resource="#ArquiteturaNeural" />
  <rdfs:label xml:lang="pt">Transformer</rdfs:label>
  <rdfs:label xml:lang="en">Transformer</rdfs:label>
  <rdfs:comment>Arquitetura neural baseada em mecanismo de atenção</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#MecanismoAtencao">
  <rdfs:subClassOf rdf:resource="#ArquiteturaNeural" />
  <rdfs:label xml:lang="pt">Mecanismo de Atenção</rdfs:label>
  <rdfs:label xml:lang="en">Attention Mechanism</rdfs:label>
  <rdfs:comment>Permite que modelo se concentre em partes relevantes da entrada</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Seq2Seq">
  <rdfs:subClassOf rdf:resource="#ArquiteturaNeural" />
  <rdfs:label xml:lang="pt">Sequence-to-Sequence</rdfs:label>
  <rdfs:label xml:lang="en">Sequence-to-Sequence</rdfs:label>
  <rdfs:comment>Arquitetura que mapeia uma sequência para outra</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#AutoAtencao">
  <rdfs:subClassOf rdf:resource="#MecanismoAtencao" />
  <rdfs:label xml:lang="pt">Auto-atenção</rdfs:label>
  <rdfs:label xml:lang="en">Self-attention</rdfs:label>
  <rdfs:comment>Mecanismo de atenção que permite elemento atender outros elementos na mesma sequência</rdfs:comment>
  <skos:altLabel>Self-attention</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#MecanismoGate">
  <rdfs:subClassOf rdf:resource="#ArquiteturaNeural" />
