</owl:Class>

<owl:Class rdf:about="#COMET">
  <rdfs:subClassOf rdf:resource="#MetricaAutomatic" />
  <rdfs:label xml:lang="pt">COMET</rdfs:label>
  <rdfs:label xml:lang="en">COMET</rdfs:label>
