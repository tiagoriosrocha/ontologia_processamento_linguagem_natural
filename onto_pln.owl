</owl:Class>

<owl:Class rdf:about="#AvaliacaoIntris">
  <rdfs:subClassOf rdf:resource="#Avaliacao" />
  <rdfs:label xml:lang="pt">Avaliação Intrínseca</rdfs:label>
  <rdfs:label xml:lang="en">Intrinsic Evaluation</rdfs:label>
