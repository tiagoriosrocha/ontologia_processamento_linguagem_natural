</owl:Class>

<owl:Class rdf:about="#Robustez">
  <rdfs:subClassOf rdf:resource="#Avaliacao" />
  <rdfs:label xml:lang="pt">Robustez</rdfs:label>
  <rdfs:label xml:lang="en">Robustness</rdfs:label>
