  <rdfs:label xml:lang="en">Retrieval</rdfs:label>
  <rdfs:comment>Processo de busca e seleção de informações relevantes</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#DenseRetrieval">
  <rdfs:subClassOf rdf:resource="#Retrieval" />
  <rdfs:label xml:lang="pt">Recuperação Densa</rdfs:label>
  <rdfs:label xml:lang="en">Dense Retrieval</rdfs:label>
  <rdfs:comment>Recuperação usando embeddings e busca em espaço vetorial contínuo</rdfs:comment>
  <skos:altLabel>Dense retrieval</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#SparseRetrieval">
  <rdfs:subClassOf rdf:resource="#Retrieval" />
  <rdfs:label xml:lang="pt">Recuperação Esparsa</rdfs:label>
  <rdfs:label xml:lang="en">Sparse Retrieval</rdfs:label>
  <rdfs:comment>Recuperação baseada em correspondência de palavras-chave (BM25, TF-IDF)</rdfs:comment>
  <skos:altLabel>Sparse retrieval</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#Reranking">
  <rdfs:subClassOf rdf:resource="#SistemaRecuperacao" />
  <rdfs:label xml:lang="pt">Recuperação Classificada</rdfs:label>
  <rdfs:label xml:lang="en">Reranking</rdfs:label>
  <rdfs:comment>Re-ordenação de documentos recuperados usando modelo mais sofisticado</rdfs:comment>
  <skos:altLabel>Reranking</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#PassageRetrieval">
  <rdfs:subClassOf rdf:resource="#Retrieval" />
  <rdfs:label xml:lang="pt">Recuperação de Passagens</rdfs:label>
  <rdfs:label xml:lang="en">Passage Retrieval</rdfs:label>
  <rdfs:comment>Recuperação de passagens curtas em vez de documentos completos</rdfs:comment>
  <skos:altLabel>Passage retrieval</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#DocumentRetrieval">
  <rdfs:subClassOf rdf:resource="#Retrieval" />
  <rdfs:label xml:lang="pt">Recuperação de Documentos</rdfs:label>
  <rdfs:label xml:lang="en">Document Retrieval</rdfs:label>
  <rdfs:comment>Recuperação de documentos completos relevantes a uma consulta</rdfs:comment>
  <skos:altLabel>Document retrieval</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#RAG">
  <rdfs:subClassOf rdf:resource="#SistemaRecuperacao" />
  <rdfs:label xml:lang="pt">Geração Aumentada por Recuperação</rdfs:label>
  <rdfs:label xml:lang="en">Retrieval-Augmented Generation</rdfs:label>
  <rdfs:comment>Combinação de recuperação de documentos com geração de linguagem para respostas mais precisas</rdfs:comment>
  <skos:altLabel>RAG</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#GraphBasedRetrieval">
  <rdfs:subClassOf rdf:resource="#SistemaRecuperacao" />
  <rdfs:label xml:lang="pt">Recuperação Baseada em Grafos</rdfs:label>
  <rdfs:label xml:lang="en">Graph-based Retrieval</rdfs:label>
  <rdfs:comment>Recuperação que explora estruturas gráficas em bases de conhecimento</rdfs:comment>
  <skos:altLabel>Graph-based retrieval</skos:altLabel>
</owl:Class>

<!-- ============ INTERPRETABILIDADE E ANÁLISE DE MODELOS ============ -->
<owl:Class rdf:about="#Interpretabilidade">
  <rdfs:label xml:lang="pt">Interpretabilidade</rdfs:label>
