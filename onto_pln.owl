</owl:Class>

<owl:Class rdf:about="#Subajuste">
  <rdfs:subClassOf rdf:resource="#DadosETreinamento" />
  <rdfs:label xml:lang="pt">subajuste</rdfs:label>
  <rdfs:label xml:lang="en">Underfitting</rdfs:label>
  <rdfs:comment>Quando modelo aprende detalhes específicos dos dados de treinamento e não generaliza</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#DataAugmentation">
  <rdfs:subClassOf rdf:resource="#DadosETreinamento" />
