  <rdfs:label xml:lang="en">Gating Mechanism</rdfs:label>
  <rdfs:comment>Mecanismo que controla fluxo de informação em redes neurais</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#FuncaoAtivacao">
  <rdfs:subClassOf rdf:resource="#ArquiteturaNeural" />
  <rdfs:label xml:lang="pt">Função de Ativação</rdfs:label>
  <rdfs:label xml:lang="en">Activation Function</rdfs:label>
  <rdfs:comment>Função que introduce não-linearidade em neurônios artificiais</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#FuncaoPerda">
  <rdfs:subClassOf rdf:resource="#ArquiteturaNeural" />
  <rdfs:label xml:lang="pt">Função de Perda</rdfs:label>
  <rdfs:label xml:lang="en">Loss Function</rdfs:label>
  <rdfs:comment>Função que mede a discrepância entre predições e valores esperados</rdfs:comment>
  <skos:altLabel>Cost function</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#MatrizPesos">
  <rdfs:subClassOf rdf:resource="#ArquiteturaNeural" />
  <rdfs:label xml:lang="pt">Matriz de Pesos</rdfs:label>
  <rdfs:label xml:lang="en">Weight Matrix</rdfs:label>
  <rdfs:comment>Parâmetros da rede neural que são aprendidos durante o treinamento</rdfs:comment>
</owl:Class>

