</owl:Class>

<owl:Class rdf:about="#Generalizacao">
  <rdfs:subClassOf rdf:resource="#Avaliacao" />
  <rdfs:label xml:lang="pt">Generalização</rdfs:label>
  <rdfs:label xml:lang="en">Generalization</rdfs:label>
  <rdfs:comment>Capacidade de um modelo funcionar bem em dados não vistos durante treinamento</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Calibration">
  <rdfs:subClassOf rdf:resource="#Avaliacao" />
