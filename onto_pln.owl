</owl:Class>

<owl:Class rdf:about="#MetricaManual">
  <rdfs:subClassOf rdf:resource="#Avaliacao" />
  <rdfs:label xml:lang="pt">Métrica Manual</rdfs:label>
  <rdfs:label xml:lang="en">Manual Metric</rdfs:label>
