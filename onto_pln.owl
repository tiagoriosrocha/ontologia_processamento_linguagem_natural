<?xml version='1.0' encoding='utf-8'?>
<rdf:RDF 
  xmlns="http://www.ufrgs.br/ontologies/onto_pln.owl#"
  xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
  xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
  xmlns:owl="http://www.w3.org/2002/07/owl#"
  xmlns:skos="http://www.w3.org/2004/02/skos/core#"
  xmlns:pln="http://www.ufrgs.br/ontologies/onto_pln.owl#"
  xml:base="http://www.ufrgs.br/ontologies/onto_pln.owl#">

<owl:Ontology rdf:about="http://www.ufrgs.br/ontologies/onto_pln.owl">
  <rdfs:label xml:lang="pt">Ontologia de Processamento de Linguagem Natural - Versão 3</rdfs:label>
  <rdfs:label xml:lang="en">Natural Language Processing Ontology - Version 3</rdfs:label>
  <rdfs:comment>Ontologia abrangente de PLN baseada no livro "Processamento de Linguagem Natural: Conceitos, Técnicas e Aplicações em Português" (BPLN, 3ª edição, 2024)</rdfs:comment>
  <owl:versionInfo>3.0</owl:versionInfo>
</owl:Ontology>

<!-- ============ CONCEITOS FUNDAMENTAIS ============ -->
<owl:Class rdf:about="#ConcetoFundamental">
  <rdfs:label xml:lang="pt">Conceito Fundamental</rdfs:label>
  <rdfs:label xml:lang="en">Fundamental Concept</rdfs:label>
  <rdfs:comment>Conceitos básicos que fundamentam a PLN</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Linguagem">
  <rdfs:subClassOf rdf:resource="#ConcetoFundamental" />
  <rdfs:label xml:lang="pt">Linguagem</rdfs:label>
  <rdfs:label xml:lang="en">Language</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#LinguaFalada">
  <rdfs:subClassOf rdf:resource="#Linguagem" />
  <rdfs:label xml:lang="pt">Língua Falada</rdfs:label>
  <rdfs:label xml:lang="en">Spoken Language</rdfs:label>
  <skos:broader rdf:resource="#Linguagem" />
</owl:Class>

<owl:Class rdf:about="#LinguaEscrita">
  <rdfs:subClassOf rdf:resource="#Linguagem" />
  <rdfs:label xml:lang="pt">Língua Escrita</rdfs:label>
  <rdfs:label xml:lang="en">Written Language</rdfs:label>
  <skos:altLabel>Texto</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#Token">
  <rdfs:subClassOf rdf:resource="#ConcetoFundamental" />
  <rdfs:label xml:lang="pt">Token</rdfs:label>
  <rdfs:label xml:lang="en">Token</rdfs:label>
  <rdfs:comment>Unidade discreta de texto (palavra, pontuação)</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Type">
  <rdfs:subClassOf rdf:resource="#ConcetoFundamental" />
  <rdfs:label xml:lang="pt">Type</rdfs:label>
  <rdfs:label xml:lang="en">Type</rdfs:label>
  <rdfs:comment>Tipo de token, forma única</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Lexema">
  <rdfs:subClassOf rdf:resource="#ConcetoFundamental" />
  <rdfs:label xml:lang="pt">Lexema</rdfs:label>
  <rdfs:label xml:lang="en">Lexeme</rdfs:label>
  <rdfs:comment>Unidade de significado convencional</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Lema">
  <rdfs:subClassOf rdf:resource="#ConcetoFundamental" />
  <rdfs:label xml:lang="pt">Lema</rdfs:label>
  <rdfs:label xml:lang="en">Lemma</rdfs:label>
  <rdfs:comment>Forma canônica de um conjunto de palavras relacionadas</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Significado">
  <rdfs:subClassOf rdf:resource="#ConceitoFundamental" />
  <rdfs:label xml:lang="pt">Significado</rdfs:label>
  <rdfs:label xml:lang="en">Meaning</rdfs:label>
</owl:Class>

<owl:Class rdf:about="#Referencia">
  <rdfs:subClassOf rdf:resource="#ConceitoFundamental" />
  <rdfs:label xml:lang="pt">Referência</rdfs:label>
  <rdfs:label xml:lang="en">Reference</rdfs:label>
  <rdfs:comment>Relação entre expressão e seu objeto no mundo</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Contexto">
  <rdfs:subClassOf rdf:resource="#ConceitoFundamental" />
  <rdfs:label xml:lang="pt">Contexto</rdfs:label>
  <rdfs:label xml:lang="en">Context</rdfs:label>
  <rdfs:comment>Informação circundante que influencia interpretação</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#ContextoLinguistico">
  <rdfs:subClassOf rdf:resource="#Contexto" />
  <rdfs:label xml:lang="pt">Contexto Linguístico</rdfs:label>
  <rdfs:label xml:lang="en">Linguistic Context</rdfs:label>
  <rdfs:comment>Contexto formado por elementos linguísticos que circundam uma unidade</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Frase">
  <rdfs:subClassOf rdf:resource="#ConceitoFundamental" />
  <rdfs:label xml:lang="pt">Frase</rdfs:label>
  <rdfs:label xml:lang="en">Phrase</rdfs:label>
  <rdfs:comment>Unidade sintática de palavras que formam um conceito</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Sentenca">
  <rdfs:subClassOf rdf:resource="#ConceitoFundamental" />
  <rdfs:label xml:lang="pt">Sentença</rdfs:label>
  <rdfs:label xml:lang="en">Sentence</rdfs:label>
  <rdfs:comment>Unidade sintática completa que transmite uma ideia ou proposição</rdfs:comment>
  <skos:altLabel>Sentenças</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#Vocabulario">
  <rdfs:subClassOf rdf:resource="#ConceitoFundamental" />
  <rdfs:label xml:lang="pt">Vocabulário</rdfs:label>
  <rdfs:label xml:lang="en">Vocabulary</rdfs:label>
  <rdfs:comment>Conjunto de palavras utilizadas em um idioma, texto ou domínio</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Vetor">
  <rdfs:subClassOf rdf:resource="#ConceitoFundamental" />
  <rdfs:label xml:lang="pt">Vetor</rdfs:label>
  <rdfs:label xml:lang="en">Vector</rdfs:label>
  <rdfs:comment>Representação numérica multidimensional de um objeto</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#VetorDeContexto">
  <rdfs:subClassOf rdf:resource="#Vetor" />
  <rdfs:label xml:lang="pt">Vetor de Contexto</rdfs:label>
  <rdfs:label xml:lang="en">Context Vector</rdfs:label>
  <rdfs:comment>Vetor que representa o contexto de uma palavra ou entidade</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#EspacoVetorial">
  <rdfs:subClassOf rdf:resource="#ConceitoFundamental" />
  <rdfs:label xml:lang="pt">Espaço Vetorial</rdfs:label>
  <rdfs:label xml:lang="en">Vector Space</rdfs:label>
  <rdfs:comment>Espaço multidimensional em que vetores representam palavras ou documentos</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#EspacoSemantico">
  <rdfs:subClassOf rdf:resource="#EspacoVetorial" />
  <rdfs:label xml:lang="pt">Espaço Semântico</rdfs:label>
  <rdfs:label xml:lang="en">Semantic Space</rdfs:label>
  <rdfs:comment>Espaço vetorial onde dimensões representam características semânticas</rdfs:comment>
  <skos:altLabel>Espaço semântico multidimensional</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#RepresentacaoDistribuida">
  <rdfs:subClassOf rdf:resource="#ConceitoFundamental" />
  <rdfs:label xml:lang="pt">Representação Distribuída</rdfs:label>
  <rdfs:label xml:lang="en">Distributed Representation</rdfs:label>
  <rdfs:comment>Representação onde significado é distribuído entre múltiplas dimensões</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#ConhecimentoLinguistico">
  <rdfs:subClassOf rdf:resource="#ConceitoFundamental" />
  <rdfs:label xml:lang="pt">Conhecimento Linguístico</rdfs:label>
  <rdfs:label xml:lang="en">Linguistic Knowledge</rdfs:label>
  <rdfs:comment>Informação sobre estruturas, regras e padrões de uma língua</rdfs:comment>
  <skos:altLabel>Bases de conhecimento</skos:altLabel>
</owl:Class>

<!-- ============ NÍVEIS LINGUÍSTICOS ============ -->
<owl:Class rdf:about="#NivelLinguistico">
  <rdfs:label xml:lang="pt">Nível Linguístico</rdfs:label>
  <rdfs:label xml:lang="en">Linguistic Level</rdfs:label>
  <rdfs:comment>Diferentes níveis de análise da linguagem</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Fonetica">
  <rdfs:subClassOf rdf:resource="#NivelLinguistico" />
  <rdfs:label xml:lang="pt">Fonética</rdfs:label>
  <rdfs:label xml:lang="en">Phonetics</rdfs:label>
  <rdfs:comment>Estudo dos sons da fala, produção, classificação e transcrição</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Fonologia">
  <rdfs:subClassOf rdf:resource="#NivelLinguistico" />
  <rdfs:label xml:lang="pt">Fonologia</rdfs:label>
  <rdfs:label xml:lang="en">Phonology</rdfs:label>
  <rdfs:comment>Estudo de padrões e distribuição de sons em uma língua</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Morfologia">
  <rdfs:subClassOf rdf:resource="#NivelLinguistico" />
  <rdfs:label xml:lang="pt">Morfologia</rdfs:label>
  <rdfs:label xml:lang="en">Morphology</rdfs:label>
  <rdfs:comment>Como morfemas se organizam para formar palavras</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Morfossintaxe">
  <rdfs:subClassOf rdf:resource="#Morfologia" />
  <rdfs:label xml:lang="pt">Morfossintaxe</rdfs:label>
  <rdfs:label xml:lang="en">Morphosyntax</rdfs:label>
  <rdfs:comment>Intersecção entre morfologia e sintaxe</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Sintaxe">
  <rdfs:subClassOf rdf:resource="#NivelLinguistico" />
  <rdfs:label xml:lang="pt">Sintaxe</rdfs:label>
  <rdfs:label xml:lang="en">Syntax</rdfs:label>
  <rdfs:comment>Organização de palavras em estruturas para formar sentenças</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#SintaxeConstituencia">
  <rdfs:subClassOf rdf:resource="#Sintaxe" />
  <rdfs:label xml:lang="pt">Sintaxe de Constituência</rdfs:label>
  <rdfs:label xml:lang="en">Constituency-based Syntax</rdfs:label>
  <rdfs:comment>Análise com base em estruturas de sintagmas</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#SintaxeDependencia">
  <rdfs:subClassOf rdf:resource="#Sintaxe" />
  <rdfs:label xml:lang="pt">Sintaxe de Dependência</rdfs:label>
  <rdfs:label xml:lang="en">Dependency-based Syntax</rdfs:label>
  <rdfs:comment>Análise com base em relações de dependência entre palavras</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Semantica">
  <rdfs:subClassOf rdf:resource="#NivelLinguistico" />
  <rdfs:label xml:lang="pt">Semântica</rdfs:label>
  <rdfs:label xml:lang="en">Semantics</rdfs:label>
  <rdfs:comment>Estudo de significado de palavras e frases</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#SemanticaSimbolia">
  <rdfs:subClassOf rdf:resource="#Semantica" />
  <rdfs:label xml:lang="pt">Semântica Simbólica</rdfs:label>
  <rdfs:label xml:lang="en">Symbolic Semantics</rdfs:label>
  <rdfs:comment>Representação explícita de significado através de símbolos</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#SemanticaDistribucional">
  <rdfs:subClassOf rdf:resource="#Semantica" />
  <rdfs:label xml:lang="pt">Semântica Distribucional</rdfs:label>
  <rdfs:label xml:lang="en">Distributional Semantics</rdfs:label>
  <rdfs:comment>Significado derivado de contexto e coocorrência</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#SemanticaVetorial">
  <rdfs:subClassOf rdf:resource="#SemanticaDistribucional" />
  <rdfs:label xml:lang="pt">Semântica Vetorial</rdfs:label>
  <rdfs:label xml:lang="en">Vector Semantics</rdfs:label>
  <rdfs:comment>Representação de significado como vetores numéricos</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#SemanticaComposicional">
  <rdfs:subClassOf rdf:resource="#Semantica" />
  <rdfs:label xml:lang="pt">Semântica Composicional</rdfs:label>
  <rdfs:label xml:lang="en">Compositional Semantics</rdfs:label>
  <rdfs:comment>Significado de uma expressão é composto a partir do significado de suas partes</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#RepresentacaoSemanticaExplicita">
  <rdfs:subClassOf rdf:resource="#SemanticaSimbolia" />
  <rdfs:label xml:lang="pt">Representação Semântica Explícita</rdfs:label>
  <rdfs:label xml:lang="en">Explicit Semantic Representation</rdfs:label>
  <rdfs:comment>Representação clara e estruturada de significado usando símbolos</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#RepresentacaoSimbolia">
  <rdfs:subClassOf rdf:resource="#SemanticaSimbolia" />
  <rdfs:label xml:lang="pt">Representação Simbólica</rdfs:label>
  <rdfs:label xml:lang="en">Symbolic Representation</rdfs:label>
  <rdfs:comment>Representação baseada em símbolos e estruturas lógicas</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#RepresentacaoHibrida">
  <rdfs:subClassOf rdf:resource="#Semantica" />
  <rdfs:label xml:lang="pt">Representação Híbrida</rdfs:label>
  <rdfs:label xml:lang="en">Hybrid Representation</rdfs:label>
  <rdfs:comment>Combinação de representação simbólica e distribuída</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#GrafoConhecimento">
  <rdfs:subClassOf rdf:resource="#SemanticaSimbolia" />
  <rdfs:label xml:lang="pt">Grafo de Conhecimento</rdfs:label>
  <rdfs:label xml:lang="en">Knowledge Graph</rdfs:label>
  <rdfs:comment>Estrutura gráfica que representa entidades e relações semânticas</rdfs:comment>
  <skos:altLabel>Knowledge Base</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#EntityLinking">
  <rdfs:subClassOf rdf:resource="#Semantica" />
  <rdfs:label xml:lang="pt">Vinculação de Entidades</rdfs:label>
  <rdfs:label xml:lang="en">Entity Linking</rdfs:label>
  <rdfs:comment>Ligação de menções de entidades no texto a entidades em base de conhecimento</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#EntityDisambiguation">
  <rdfs:subClassOf rdf:resource="#Semantica" />
  <rdfs:label xml:lang="pt">Desambiguação de Entidades</rdfs:label>
  <rdfs:label xml:lang="en">Entity Disambiguation</rdfs:label>
  <rdfs:comment>Resolução de qual entidade uma menção no texto refere-se</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Pragmatica">
  <rdfs:subClassOf rdf:resource="#NivelLinguistico" />
  <rdfs:label xml:lang="pt">Pragmática</rdfs:label>
  <rdfs:label xml:lang="en">Pragmatics</rdfs:label>
  <rdfs:comment>Como orações são utilizadas para fins comunicativos</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Prosodeia">
  <rdfs:subClassOf rdf:resource="#Pragmatica" />
  <rdfs:label xml:lang="pt">Prosódia</rdfs:label>
  <rdfs:label xml:lang="en">Prosody</rdfs:label>
  <rdfs:comment>Padrões de entonação, duração e volume</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Entonacao">
  <rdfs:subClassOf rdf:resource="#Prosodeia" />
  <rdfs:label xml:lang="pt">Entonação</rdfs:label>
  <rdfs:label xml:lang="en">Intonation</rdfs:label>
  <rdfs:comment>Variação de frequência fundamental na fala</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Discurso">
  <rdfs:subClassOf rdf:resource="#NivelLinguistico" />
  <rdfs:label xml:lang="pt">Discurso</rdfs:label>
  <rdfs:label xml:lang="en">Discourse</rdfs:label>
  <rdfs:comment>Relações entre frases/partes de um texto; estrutura textual</rdfs:comment>
</owl:Class>

<!-- ============ TAREFAS DE PLN - NÍVEL 1 (Categorias Principais) ============ -->
<owl:Class rdf:about="#TarefaPLN">
  <rdfs:label xml:lang="pt">Tarefa PLN</rdfs:label>
  <rdfs:label xml:lang="en">NLP Task</rdfs:label>
  <rdfs:comment>Tarefas computacionais em PLN</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#TarefaAnalise">
  <rdfs:subClassOf rdf:resource="#TarefaPLN" />
  <rdfs:label xml:lang="pt">Tarefa de Análise</rdfs:label>
  <rdfs:label xml:lang="en">Analysis Task</rdfs:label>
  <rdfs:comment>Tarefas que analisam propriedades linguísticas de textos</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#TarefaGeracao">
  <rdfs:subClassOf rdf:resource="#TarefaPLN" />
  <rdfs:label xml:lang="pt">Tarefa de Geração</rdfs:label>
  <rdfs:label xml:lang="en">Generation Task</rdfs:label>
  <rdfs:comment>Tarefas que geram novo texto ou fala</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#TarefaClassificacao">
  <rdfs:subClassOf rdf:resource="#TarefaPLN" />
  <rdfs:label xml:lang="pt">Tarefa de Classificação</rdfs:label>
  <rdfs:label xml:lang="en">Classification Task</rdfs:label>
  <rdfs:comment>Tarefas que atribuem categorias ou etiquetas</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#TarefaRecuperacao">
  <rdfs:subClassOf rdf:resource="#TarefaPLN" />
  <rdfs:label xml:lang="pt">Tarefa de Recuperação</rdfs:label>
  <rdfs:label xml:lang="en">Retrieval Task</rdfs:label>
  <rdfs:comment>Tarefas de busca e recuperação de informação</rdfs:comment>
</owl:Class>

<!-- ============ TAREFAS - ANÁLISE ============ -->
<owl:Class rdf:about="#Sentenciacao">
  <rdfs:subClassOf rdf:resource="#TarefaAnalise" />
  <rdfs:label xml:lang="pt">Sentenciação</rdfs:label>
  <rdfs:label xml:lang="en">Sentence Segmentation</rdfs:label>
  <rdfs:comment>Segmentação de texto em sentenças</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Tokenizacao">
  <rdfs:subClassOf rdf:resource="#TarefaAnalise" />
  <rdfs:label xml:lang="pt">Tokenização</rdfs:label>
  <rdfs:label xml:lang="en">Tokenization</rdfs:label>
  <rdfs:comment>Segmentação de texto em tokens</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#TokenizacaoTradicional">
  <rdfs:subClassOf rdf:resource="#Tokenizacao" />
  <rdfs:label xml:lang="pt">Tokenização Tradicional</rdfs:label>
  <rdfs:label xml:lang="en">Traditional Tokenization</rdfs:label>
  <rdfs:comment>Segmentação baseada em espaços em branco e pontuação</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#TokenizacaoSubpalavra">
  <rdfs:subClassOf rdf:resource="#Tokenizacao" />
  <rdfs:label xml:lang="pt">Tokenização em Subpalavras</rdfs:label>
  <rdfs:label xml:lang="en">Subword Tokenization</rdfs:label>
  <rdfs:comment>Segmentação em unidades menores que palavras</rdfs:comment>
  <skos:altLabel>BPE</skos:altLabel>
  <skos:altLabel>Byte Pair Encoding</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#Normalizacao">
  <rdfs:subClassOf rdf:resource="#TarefaAnalise" />
  <rdfs:label xml:lang="pt">Normalização</rdfs:label>
  <rdfs:label xml:lang="en">Normalization</rdfs:label>
  <rdfs:comment>Padronização de formas textuais</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Lematizacao">
  <rdfs:subClassOf rdf:resource="#TarefaAnalise" />
  <rdfs:label xml:lang="pt">Lematização</rdfs:label>
  <rdfs:label xml:lang="en">Lemmatization</rdfs:label>
  <rdfs:comment>Redução de palavras a seus lemas</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Stemming">
  <rdfs:subClassOf rdf:resource="#TarefaAnalise" />
  <rdfs:label xml:lang="pt">Stemming</rdfs:label>
  <rdfs:label xml:lang="en">Stemming</rdfs:label>
  <rdfs:comment>Redução de palavras a raízes através de regras heurísticas</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#StopWords">
  <rdfs:subClassOf rdf:resource="#TarefaAnalise" />
  <rdfs:label xml:lang="pt">Stop Words</rdfs:label>
  <rdfs:label xml:lang="en">Stop Words</rdfs:label>
  <rdfs:comment>Palavras com baixo valor informativo frequentemente removidas (artigos, preposições)</rdfs:comment>
  <skos:altLabel>Stop words</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#StopWordRemoval">
  <rdfs:subClassOf rdf:resource="#TarefaAnalise" />
  <rdfs:label xml:lang="pt">Remoção de Stop Words</rdfs:label>
  <rdfs:label xml:lang="en">Stop Word Removal</rdfs:label>
  <rdfs:comment>Remoção de palavras com baixo valor informativo de textos</rdfs:comment>
  <skos:altLabel>Stop word removal</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#AnotacaoLexical">
  <rdfs:subClassOf rdf:resource="#TarefaAnalise" />
  <rdfs:label xml:lang="pt">Anotação Lexical</rdfs:label>
  <rdfs:label xml:lang="en">Lexical Annotation</rdfs:label>
  <rdfs:comment>Anotação de informações léxicas em textos</rdfs:comment>
  <skos:altLabel>Anotação lexical</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#EtiquetacaoMorfossintatica">
  <rdfs:subClassOf rdf:resource="#TarefaAnalise" />
  <rdfs:label xml:lang="pt">Etiquetação Morfossintática</rdfs:label>
  <rdfs:label xml:lang="en">Part-of-Speech Tagging</rdfs:label>
  <rdfs:comment>Atribuição de categorias gramaticais a palavras</rdfs:comment>
  <skos:altLabel>PoS Tagging</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#AnotacaoAtributasMorfologicos">
  <rdfs:subClassOf rdf:resource="#TarefaAnalise" />
  <rdfs:label xml:lang="pt">Anotação de Atributos Morfológicos</rdfs:label>
  <rdfs:label xml:lang="en">Morphological Features Annotation</rdfs:label>
  <rdfs:comment>Marcação de características morfológicas (gênero, número, etc.)</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#AnalisesintaticaConstituencia">
  <rdfs:subClassOf rdf:resource="#TarefaAnalise" />
