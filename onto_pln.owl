</owl:Class>

<owl:Class rdf:about="#AnaliseErro">
  <rdfs:subClassOf rdf:resource="#Avaliacao" />
  <rdfs:label xml:lang="pt">Análise de Erro</rdfs:label>
  <rdfs:label xml:lang="en">Error Analysis</rdfs:label>
