<owl:Class rdf:about="#PreTreinamento">
  <rdfs:subClassOf rdf:resource="#Treinamento" />
  <rdfs:label xml:lang="pt">Pré-treinamento</rdfs:label>
  <rdfs:label xml:lang="en">Pre-training</rdfs:label>
  <rdfs:comment>Treinamento em larga escala em corpus geral antes de tarefa específica</rdfs:comment>
  <skos:altLabel>Pré-treinamento</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#FineTuning">
  <rdfs:subClassOf rdf:resource="#Treinamento" />
  <rdfs:label xml:lang="pt">Ajuste Fino</rdfs:label>
  <rdfs:label xml:lang="en">Fine-tuning</rdfs:label>
  <rdfs:comment>Adaptação de modelo pré-treinado para tarefa específica</rdfs:comment>
  <skos:altLabel>Fine-tuning</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#Inferencia">
  <rdfs:subClassOf rdf:resource="#ComponentePipelinePLN" />
  <rdfs:label xml:lang="pt">Inferência</rdfs:label>
  <rdfs:label xml:lang="en">Inference</rdfs:label>
  <rdfs:comment>Aplicação do modelo treinado em dados novos para gerar predições</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#PosProcessamento">
  <rdfs:subClassOf rdf:resource="#ComponentePipelinePLN" />
  <rdfs:label xml:lang="pt">Pós-processamento</rdfs:label>
  <rdfs:label xml:lang="en">Post-processing</rdfs:label>
  <rdfs:comment>Etapa final que refina ou formata os resultados da inferência</rdfs:comment>
  <skos:altLabel>Pós-processamento</skos:altLabel>
</owl:Class>

<!-- ============ MODELOS E TÉCNICAS DE LLM ============ -->
<owl:Class rdf:about="#TecnicaLLM">
  <rdfs:label xml:lang="pt">Técnica de LLM</rdfs:label>
  <rdfs:label xml:lang="en">LLM Technique</rdfs:label>
  <rdfs:comment>Técnicas e métodos específicos para trabalhar com modelos de linguagem de grande escala</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#Prompt">
  <rdfs:subClassOf rdf:resource="#TecnicaLLM" />
  <rdfs:label xml:lang="pt">Prompt</rdfs:label>
  <rdfs:label xml:lang="en">Prompt</rdfs:label>
  <rdfs:comment>Texto de entrada que instrui o modelo sobre o que fazer</rdfs:comment>
</owl:Class>

<owl:Class rdf:about="#InContextLearning">
  <rdfs:subClassOf rdf:resource="#TecnicaLLM" />
  <rdfs:label xml:lang="pt">Aprendizado em Contexto</rdfs:label>
  <rdfs:label xml:lang="en">In-context Learning</rdfs:label>
  <rdfs:comment>Adaptação de modelo através de exemplos fornecidos no prompt</rdfs:comment>
  <skos:altLabel>In-context learning</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#FewShotLearningLLM">
  <rdfs:subClassOf rdf:resource="#TecnicaLLM" />
  <rdfs:label xml:lang="pt">Few-shot Learning</rdfs:label>
  <rdfs:label xml:lang="en">Few-shot Learning</rdfs:label>
  <rdfs:comment>Aprendizado com poucos exemplos no prompt</rdfs:comment>
  <skos:altLabel>Few-shot learning</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#ZeroShotLearningLLM">
  <rdfs:subClassOf rdf:resource="#TecnicaLLM" />
  <rdfs:label xml:lang="pt">Zero-shot Learning</rdfs:label>
  <rdfs:label xml:lang="en">Zero-shot Learning</rdfs:label>
  <rdfs:comment>Execução de tarefa sem exemplos específicos</rdfs:comment>
  <skos:altLabel>Zero-shot learning</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#ChainOfThought">
  <rdfs:subClassOf rdf:resource="#TecnicaLLM" />
  <rdfs:label xml:lang="pt">Chain-of-thought</rdfs:label>
  <rdfs:label xml:lang="en">Chain-of-thought</rdfs:label>
  <rdfs:comment>Técnica que pede ao modelo que mostre o raciocínio passo a passo</rdfs:comment>
  <skos:altLabel>Chain-of-thought reasoning</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#InstructionTuning">
  <rdfs:subClassOf rdf:resource="#TecnicaLLM" />
  <rdfs:label xml:lang="pt">Ajuste por Instruções</rdfs:label>
  <rdfs:label xml:lang="en">Instruction Tuning</rdfs:label>
  <rdfs:comment>Treinamento do modelo em diversas tarefas descritas por instruções</rdfs:comment>
  <skos:altLabel>Instruction tuning</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#Alignment">
  <rdfs:subClassOf rdf:resource="#TecnicaLLM" />
  <rdfs:label xml:lang="pt">Alinhamento</rdfs:label>
  <rdfs:label xml:lang="en">Alignment</rdfs:label>
  <rdfs:comment>Alinhamento de modelo com valores e comportamentos desejados</rdfs:comment>
  <skos:altLabel>Model alignment</skos:altLabel>
</owl:Class>

<owl:Class rdf:about="#Hallucination">
  <rdfs:subClassOf rdf:resource="#TecnicaLLM" />
  <rdfs:label xml:lang="pt">Alucinação</rdfs:label>
  <rdfs:label xml:lang="en">Hallucination</rdfs:label>
  <rdfs:comment>Geração de conteúdo fictício ou incorreto pelo modelo, aparentando ser verdadeiro</rdfs:comment>
</owl:Class>

<!-- ============ SISTEMAS DE RECUPERAÇÃO E RAG ============ -->
<owl:Class rdf:about="#SistemaRecuperacao">
  <rdfs:label xml:lang="pt">Sistema de Recuperação</rdfs:label>
  <rdfs:label xml:lang="en">Retrieval System</rdfs:label>
